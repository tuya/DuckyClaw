# CONFIG_ENABLE_COMP_AI_DISPLAY is not set
CONFIG_CRON_THREAD_STACK=1536
CONFIG_WS_SERVER_STACK_SIZE=1536
CONFIG_ACP_CLIENT_STACK_SIZE=2048
CONFIG_OUTBOUND_STACK_SIZE=3072
CONFIG_IM_FS_POLL_STACK=3072
CONFIG_IM_TG_POLL_STACK=3072
CONFIG_IM_DC_POLL_STACK=3072
CONFIG_IM_WX_POLL_STACK=3072
CONFIG_IM_WX_QR_STACK=3072
CONFIG_DUCKY_CLAW_AGENT_STACK=2560
CONFIG_DUCKY_CLAW_CONTEXT_BUF_SIZE=16384
CONFIG_BOARD_CHOICE_ESP32=y
CONFIG_BOARD_CHOICE_BREAD_COMPACT_WIFI=y
CONFIG_AI_INPUT_STACK_SIZE=2048
CONFIG_AI_PLAYER_STACK_SIZE=2048
CONFIG_AI_CLIENT_STACK_SIZE=2560
# CONFIG_ENABLE_AI_MONITOR is not set
CONFIG_AI_DL_IMAGE_UNIT_SIZE=2048
CONFIG_ENABLE_MBEDTLS_SSL_MAX_FRAGMENT_LENGTH=y
CONFIG_ENABLE_MBEDTLS_SSL_MAX_CONTENT_LEN=4096
CONFIG_ENABLE_CUSTOM_CONFIG=y
CONFIG_ENABLE_BUTTON=y
